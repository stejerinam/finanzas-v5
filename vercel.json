{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/parse", "dest": "/api/parse.js" },
    { "src": "/api/categorize", "dest": "/api/categorize.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
